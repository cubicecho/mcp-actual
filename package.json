{
  "name": "mcp-actual",
  "version": "0.5.0",
  "private": true,
  "description": "MCP Actual - expose an Actual Budget server's data to agents over MCP",
  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "mcp-actual-stdio": "dist/stdio.js"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "dev:stdio": "node --env-file-if-exists=.env src/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "build:docker": "docker build -t mcp-actual .",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "stdio": "node --env-file-if-exists=.env dist/stdio.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "npm run check:biome && npm run check:types",
    "check:biome": "biome check .",
    "check:fix": "biome check --write .",
    "check:types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "@actual-app/api": "26.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
