# Copy to `.env` and fill in the three REQUIRED values. `docker compose up`
# reads this file directly; `npm start` reads it via --env-file-if-exists.
#
# There is no API key or username: an Actual sync server authenticates with a
# single password, and the budget is chosen by its Sync ID.

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# 1. Where your Actual sync server lives — scheme + host (+ port if non-standard),
#    no trailing path. This is the same URL you open the Actual web UI at.
#    Examples: https://budget.example.com
#              http://192.168.1.50:5006
#              http://actual_server:5006     (another service on the same Docker network)
ACTUAL_SERVER_URL=https://budget.example.com

# 2. The sync server's password — what you type on the Actual login screen.
#    Not a per-user password: Actual servers have exactly one.
ACTUAL_PASSWORD=change-me

# 3. Which budget to open, identified by its Sync ID (a UUID).
#    Find it in the Actual UI: Settings → Advanced settings → "Sync ID".
#    This is NOT the budget's display name and NOT the local `My-Finances-xxxx`
#    folder name.
ACTUAL_SYNC_ID=00000000-0000-0000-0000-000000000000

# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# End-to-end encryption password. Only set this if you enabled E2E encryption
# for the budget (Settings → Encryption). Leave unset otherwise.
# ACTUAL_ENCRYPTION_PASSWORD=

# Bearer token required on requests to /mcp. Generate with `openssl rand -hex 32`.
# Leave unset only if the server is unreachable from untrusted networks —
# without it, anyone who can reach the port can read your finances.
# MCP_ACTUAL_TOKEN=

# Trusted local network escape hatch: `true` disables auth entirely, ignoring
# MCP_ACTUAL_TOKEN above.
# SECURE_LOCAL_NET=true

# Where the downloaded budget is cached between runs. Inside Docker this is
# /data (a mounted volume) and should not be changed; locally it defaults to ./data.
# DATA_DIR=./data

# HTTP port the server listens on (inside the container; remap via compose ports).
# PORT=3000
